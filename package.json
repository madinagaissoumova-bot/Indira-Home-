{
  "name": "indira-home",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test --require ./tests/register.cjs tests/**/*.test.ts",
    "check:docs": "node --test --require ./tests/register.cjs tests/documentation-structure.test.ts",
    "prisma:generate": "node scripts/require-supabase-url.mjs prisma generate",
    "prisma:migrate": "node scripts/require-supabase-url.mjs prisma migrate deploy",
    "prisma:push": "node scripts/require-supabase-url.mjs prisma db push",
    "prisma:seed": "node scripts/require-supabase-url.mjs tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
